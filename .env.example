# Jiggabyte Command Center - Environment Configuration

# Database Connection String
# PostgreSQL example: postgresql://username:password@localhost:5432/leads_db
# SQLite fallback (default): sqlite:///./leads.db
DATABASE_URL=sqlite:///./leads.db

# API Keys
GEMINI_API_KEY=your_gemini_api_key_here

# Server Configuration
PORT=8000
HOST=0.0.0.0
